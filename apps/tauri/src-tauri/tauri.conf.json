{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Diaryx",
  "version": "1.4.1",
  "identifier": "org.diaryx.desktop",
  "build": {
    "beforeDevCommand": "cd ../web && bun run dev --port 5174 --host",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "cd ../web && bunx vite build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Diaryx",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DOCUMENT/**",
          "$DESKTOP/**",
          "$DOWNLOAD/**",
          "$PICTURE/**",
          "$VIDEO/**",
          "$AUDIO/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$APPCACHE/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "iOS": {
      "infoPlist": "Info.ios.plist"
    },
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "Entitlements.plist"
    },
    "category": "Productivity"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
