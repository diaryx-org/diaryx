{
  "name": "diaryx-web",
  "private": true,
  "version": "1.4.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:bun": "bun serve.ts",
    "build:bun": "bun run build:wasm && bun build.ts",
    "deploy": "bun run build && bunx wrangler deploy",
    "build": "bun run build:wasm && vite build",
    "build:wasm": "bash ../../scripts/build-wasm.sh",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "tauri": "cd ../tauri && cargo tauri",
    "tauri:setup": "mkdir -p src/lib/wasm && cp src/lib/wasm-stub.js src/lib/wasm/diaryx_wasm.js"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@choochmeque/tauri-plugin-iap-api": "^0.8.2",
    "@extism/extism": "^2.0.0-rc13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-bubble-menu": "^3.22.2",
    "@tiptap/extension-code-block": "^3.22.2",
    "@tiptap/extension-floating-menu": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/extension-typography": "^3.22.2",
    "@tiptap/markdown": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@zip.js/zip.js": "^2.8.26",
    "comlink": "^4.4.2",
    "dompurify": "^3.3.3",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "undici": "^7.24.7"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/bun": "^1.3.11",
    "@types/dompurify": "^3.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "bits-ui": "^2.17.2",
