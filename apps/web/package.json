    "clsx": "^2.1.1",
    "jsdom": "^29.0.2",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.59.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "4.2.2",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^8.0.7",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.3",
    "wrangler": "^4.81.0"
  }
