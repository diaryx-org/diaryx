{
  "name": "diaryx",
  "compatibility_date": "2026-02-07",
  "workers_dev": false,
  "preview_urls": true,
  "main": "./worker/index.ts",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "routes": [
    {
      "pattern": "app.diaryx.org",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
